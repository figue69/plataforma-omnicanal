# Copiar a .env y completar los valores

# Supabase — connection string directo (Settings → Database → URI)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROYECTO.supabase.co:5432/postgres

# JWT — cambiar por un string aleatorio largo en producción
JWT_SECRET=cambia-esto-por-un-secreto-largo-en-produccion

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Proveedores (opcionales)
TOURBO_API_KEY=
SERPAPI_KEY=
